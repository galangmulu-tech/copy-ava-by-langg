--// PARTRY TIMING GUI - FIXED VERSION

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

pcall(function()
    game.CoreGui:FindFirstChild("ParryTimingGUI"):Destroy()
end)

-- GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "ParryTimingGUI"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = game.CoreGui

local Main = Instance.new("Frame")
Main.Parent = ScreenGui
Main.Size = UDim2.new(0,230,0,120)
Main.Position = UDim2.new(0.5,-115,0.1,0)
Main.BackgroundColor3 = Color3.fromRGB(20,20,20)
Main.BorderSizePixel = 0
Main.Active = true
Main.Draggable = true

local Corner = Instance.new("UICorner")
Corner.Parent = Main

local Title = Instance.new("TextLabel")
Title.Parent = Main
Title.Size = UDim2.new(1,0,0,30)
Title.BackgroundTransparency = 1
Title.Text = "PARRY TIMING"
Title.TextColor3 = Color3.new(1,1,1)
Title.TextScaled = true
Title.Font = Enum.Font.GothamBold

local Status = Instance.new("TextLabel")
Status.Parent = Main
Status.Position = UDim2.new(0,0,0,35)
Status.Size = UDim2.new(1,0,0,35)
Status.BackgroundTransparency = 1
Status.Text = "SAFE"
Status.TextColor3 = Color3.fromRGB(0,255,0)
Status.TextScaled = true
Status.Font = Enum.Font.GothamBold

local Distance = Instance.new("TextLabel")
Distance.Parent = Main
Distance.Position = UDim2.new(0,0,0,75)
Distance.Size = UDim2.new(1,0,0,25)
Distance.BackgroundTransparency = 1
Distance.Text = "DISTANCE : 0"
Distance.TextColor3 = Color3.new(1,1,1)
Distance.TextScaled = true
Distance.Font = Enum.Font.Gotham

-- MAIN LOOP
RunService.RenderStepped:Connect(function()

    local Character = LocalPlayer.Character
    if not Character then return end

    local Root = Character:FindFirstChild("HumanoidRootPart")
    if not Root then return end

    local Closest = math.huge

    for _,Player in ipairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer and Player.Character then

            local EnemyRoot = Player.Character:FindFirstChild("HumanoidRootPart")

            if EnemyRoot then
                local Dist = (Root.Position - EnemyRoot.Position).Magnitude

                if Dist < Closest then
                    Closest = Dist
                end
            end
        end
    end

    if Closest == math.huge then
        Closest = 0
    end

    Distance.Text = "DISTANCE : "..math.floor(Closest)

    if Closest <= 8 then
        Status.Text = "PARRY NOW!"
        Status.TextColor3 = Color3.fromRGB(255,0,0)

    elseif Closest <= 15 then
        Status.Text = "GET READY"
        Status.TextColor3 = Color3.fromRGB(255,255,0)

    else
        Status.Text = "SAFE"
        Status.TextColor3 = Color3.fromRGB(0,255,0)
    end
end)
